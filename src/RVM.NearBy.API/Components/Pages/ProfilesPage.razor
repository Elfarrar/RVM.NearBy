@page "/profiles"
@using RVM.NearBy.Domain.Entities
@using RVM.NearBy.Domain.Interfaces
@inject IUserProfileRepository ProfileRepo

<h1>Profiles</h1>

<div class="search-bar">
    <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" placeholder="Search profiles..." class="input-sm" />
</div>

@if (_loaded)
{
    @if (_profiles.Count == 0)
    {
        <div class="empty-state">No profiles found.</div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Display Name</th>
                    <th>Active</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var profile in _profiles)
                {
                    <tr>
                        <td>@profile.Username</td>
                        <td>@profile.DisplayName</td>
                        <td><span class="@(profile.IsActive ? "status-active" : "status-inactive")">@(profile.IsActive ? "Yes" : "No")</span></td>
                        <td>@profile.CreatedAt.ToString("d")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{
    <div class="loading">Loading profiles...</div>
}

@code {
    private List<UserProfile> _profiles = [];
    private string _search = "";
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        await Search();
    }

    private async Task OnSearch()
    {
        await Search();
    }

    private async Task Search()
    {
        _loaded = false;
        _profiles = await ProfileRepo.SearchAsync(string.IsNullOrWhiteSpace(_search) ? null : _search, 0, 50);
        _loaded = true;
    }
}
